# Shared
COMPOSE_PROJECT_NAME=skilix

# PostgreSQL
POSTGRES_DB=skilix
POSTGRES_USER=skilix
POSTGRES_PASSWORD=skilix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://skilix:skilix@postgres:5432/skilix

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Backend
DJANGO_SETTINGS_MODULE=skilix.settings
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DRF_THROTTLE_ANON_RATE=100/hour
DRF_THROTTLE_USER_RATE=1000/hour
DRF_THROTTLE_AUTH_RATE=10/minute
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=false
JWT_BLACKLIST_AFTER_ROTATION=true
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Frontend
VITE_API_URL=http://localhost:8000/api
DISABLE_HMR=false
VITE_USE_MOCK_API=false

# MinIO / S3-compatible media storage
MINIO_ROOT_USER=skilix-minio
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=skilix-media
AWS_ACCESS_KEY_ID=skilix-minio
AWS_SECRET_ACCESS_KEY=change-me
AWS_STORAGE_BUCKET_NAME=skilix-media
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=true
AWS_QUERYSTRING_EXPIRE=3600

# Email delivery
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=demtse.yibabe@gmail.com
EMAIL_HOST_PASSWORD=<gmail-app-password>
EMAIL_TIMEOUT=10
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=demtse.yibabe@gmail.com
FRONTEND_URL=http://localhost:3000

# Dokploy production example values:
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<generate-a-strong-50+ character secret>
# DJANGO_ALLOWED_HOSTS=api.example.com,backend
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_TOKEN_DAYS=7
# JWT_ROTATE_REFRESH_TOKENS=false
# JWT_BLACKLIST_AFTER_ROTATION=true
# DATABASE_URL=postgresql://skilix:<strong-db-password>@postgres:5432/skilix
# POSTGRES_PASSWORD=<strong-db-password>
# MINIO_ROOT_USER=<strong-minio-user>
# MINIO_ROOT_PASSWORD=<strong-minio-password>
# AWS_ACCESS_KEY_ID=<strong-minio-user>
# AWS_SECRET_ACCESS_KEY=<strong-minio-password>
# AWS_STORAGE_BUCKET_NAME=skilix-media
# AWS_S3_ENDPOINT_URL=http://minio:9000
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=demtse.yibabe@gmail.com
# EMAIL_HOST_PASSWORD=<gmail-app-password>
# DEFAULT_FROM_EMAIL=demtse.yibabe@gmail.com
# FRONTEND_URL=https://app.example.com
# VITE_API_URL=https://api.example.com/api
