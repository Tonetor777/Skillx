# Shared
COMPOSE_PROJECT_NAME=skilix

# PostgreSQL
POSTGRES_DB=skilix
POSTGRES_USER=skilix
POSTGRES_PASSWORD=skilix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://skilix:skilix@postgres:5432/skilix

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Backend
DJANGO_SETTINGS_MODULE=skilix.settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# Frontend
VITE_API_URL=http://localhost:8000/api
DISABLE_HMR=false
VITE_USE_MOCK_API=false

# Future production integrations
CLOUDINARY_URL=
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@skilix.local
