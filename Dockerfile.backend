FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DJANGO_DEBUG=false

WORKDIR /app

COPY apps/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/backend/ .

RUN DJANGO_SECRET_KEY=build-time-secret-key-with-more-than-fifty-safe-characters-only python manage.py collectstatic --noinput

EXPOSE 8000

CMD ["gunicorn", "skilix.wsgi:application", "--bind", "0.0.0.0:8000"]
